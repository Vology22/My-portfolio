        function eventObrab(name, id, value) {
            //var banner-show = document.getElementById("ads-banner");
            //banner-show.classList.add("ads-banner-show");
            switch (name) {
                case 'onAdsLoadEvent': {
                    if (value == "halo") {
                        parent.postMessage("surok_vast_halo", "*");
                        console.info('vast_halo VPAID');
                    }
                    break;
                }
                case 'onAdsEndEvent': {
                    if (value == "endhalo") {
                        parent.postMessage("surok_vast_nothalo", "*");
                        console.info('vast_endhalo VPAID');
                    }
                    break;
                }
                case 'visibility': {
                    console.log("Видимость VPAID - ", value);
                    visible_vastroll_vid = parseInt(value);
                    break;
                }
                case 'impression': {
                    //var banner-show = document.getElementById("ads-banner");             
                    // document.getElementById("ads-banner").classList.add("ads-banner-hide");
                    // document.getElementById("ads-banner");.classList.remove("ads-banner-show");

                    if (!is_adv) SendAllAdvVastroll(id_pl, country);
                    is_adv = true;
                    SendAdvStatistic(idDomen, id, id_pl);
                    parent.postMessage("surok_start_reklam", "*");
                    console.info('vast_Impression VPAID');
                    console.info('vast_Sender VPAID Test ' + is_each);
                    console.info('vast_visability VPAID Test ' + visible_vastroll_vid);
                    if (!is_each) {
                        if (!visible_vastroll) {
                            SendBlockVastroll(id_pl, id, country, slej, mark, salt);
                            SendVisibileVastroll(id_pl, visible_vastroll_vid, country);
                        }
                    } else {
                        console.info('vast_Sender VPAID ' + is_each);
                        SendVisibileVastroll(id_pl, visible_vastroll_vid, country);
                    }
                    SendVisibileVastrollComp(id, visible_vastroll_vid);
                    visible_vastroll++;
                    break;
                }
                case 'complete': {
                    //var banner-show = document.getElementById("ads-banner"); 
                    document.getElementById("ads-banner").classList.add("ads-banner-show");
                    document.getElementById("ads-banner").classList.remove("ads-banner-hide");

                    parent.postMessage("surok_complete_adv", "*");
                    console.info('vast_complete VPAID');
                    break;
                }
                case 'userClose': {
                    parent.postMessage("surok_complete_adv", "*");
                    console.info('vast_complete VPAID');
                    break;
                }
                case 'content': {
                    if (value == 'start') {
                        if (!is_adv) parent.postMessage("surok_no_reklam", "*");
                        if (is_adv) parent.postMessage("surok_play_reklam", "*");
                        parent.postMessage("surok_check_reklamend", "*");
                        console.info('play VPAID');
                    } else if (value == 'finish') {
                        parent.postMessage("surok_check_reklamend", "*");
                        console.info('end VPAID');
                    } else if (value == 'final_content') {
                        parent.postMessage("surok_check_reklamend", "*");
                        console.info('FINISH_ALL_VPAID');
                        break;
                    }
                    break;
                }
            }
        }

