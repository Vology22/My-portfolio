                        console.info('vast_endhalo VPAID');
                    }
                    break;
                }
                case 'visibility': {
                    console.log("Видимость VPAID - ", value);
                    visible_vastroll_vid = parseInt(value);
                    break;
                }
                case 'impression': {
                    if (!is_adv) SendAllAdvVastroll(id_pl, country);
                    is_adv = true;
                    parent.postMessage("surok_start_reklam", "*");
                    console.info('vast_Impression VPAID');
                    console.info('vast_Sender VPAID Test ' + is_each);
                    console.info('vast_visability VPAID Test ' + visible_vastroll_vid);
                    SendAdvStatistic(idDomen, id, id_pl);
