                        SendVisibileVastroll(id_pl, visible_vastroll_vid, country);
                    }
                    SendVisibileVastrollComp(id, visible_vastroll_vid);
                    visible_vastroll++;
                    break;
                }
                case 'complete': {
                    parent.postMessage("surok_complete_adv", "*");
                    console.info('vast_complete VPAID');
                    break;
                }
                case 'userClose': {
                    parent.postMessage("surok_complete_adv", "*");
                    console.info('vast_complete VPAID');
                    break;
                }
                case 'content': {
                    if (value == 'start') {
                        if (!is_adv) parent.postMessage("surok_no_reklam", "*");
                        if (is_adv) parent.postMessage("surok_play_reklam", "*");
                        parent.postMessage("surok_check_reklamend", "*");
                        console.info('play VPAID');
                    } else if (value == 'finish') {
                        parent.postMessage("surok_check_reklamend", "*");
                        console.info('end VPAID');
                    } else if (value == 'final_content') {
                        parent.postMessage("surok_check_reklamend", "*");
                        console.info('FINISH_ALL_VPAID');
                        break;
                    }
                    break;
                }
            }
        }

