        function eventObrab(name, id, value) {
            switch (name) {
                case 'onAdsLoadEvent': {
                    if (value == "halo") {
                        parent.postMessage("surok_vast_halo", "*");
                        console.info('vast_halo VPAID');
                    }
                    break;
